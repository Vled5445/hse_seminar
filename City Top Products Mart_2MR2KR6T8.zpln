        "code": "SUCCESS",
        "msg": [
          {
            "type": "TEXT",
            "data": "Объединенные данные с revenue:\n+--------+-------+----------+------------+---+-----+-------+\n|order_id|city   |product_id|product_name|qty|price|revenue|\n+--------+-------+----------+------------+---+-----+-------+\n|o7      |Hamburg|p1        |Ring VOLA   |10 |10.0 |100.0  |\n|o3      |Berlin |p1        |Ring VOLA   |1  |10.0 |10.0   |\n|o1      |Berlin |p1        |Ring VOLA   |2  |10.0 |20.0   |\n|o5      |Munich |p2        |Ring POROG  |3  |30.0 |90.0   |\n|o2      |Berlin |p2        |Ring POROG  |1  |30.0 |30.0   |\n|o6      |Munich |p3        |Ring TISHINA|1  |7.0  |7.0    |\n|o4      |Berlin |p3        |Ring TISHINA|5  |7.0  |35.0   |\n+--------+-------+----------+------------+---+-----+-------+\n\n"
          }
        ]
      }
    },
    {
      "text": "%spark.pyspark\n\ncity_product_metrics = (\n    enriched_orders\n    .groupBy(\"city\", \"product_id\", \"product_name\")\n    .agg(\n        F.count(\"order_id\").alias(\"orders_cnt\"),\n        F.sum(\"qty\").alias(\"qty_sum\"),\n        F.sum(\"revenue\").alias(\"revenue_sum\")\n    )\n)\n\nprint(\"Метрики по городам и продуктам:\")\ncity_product_metrics.orderBy(\"city\", F.col(\"revenue_sum\").desc()).show(truncate=False)",
      "user": "anonymous",
